{
  "name": "mf-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --project shell",
    "start:shell": "ng serve --project shell",
    "start:product": "ng serve --project product",
    "start:order": "ng serve --project order",
    "start:cart": "ng serve --project cart",
    "start:auth": "ng serve --project auth",
    "build": "ng build",
    "build:shell": "ng build --project shell",
    "build:product": "ng build --project product",
    "build:order": "ng build --project order",
    "build:cart": "ng build --project cart",
    "build:auth": "ng build --project auth",
    "build:all": "npm run build:shell && npm run build:product && npm run build:order && npm run build:cart && npm run build:auth",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "run:all": "node node_modules/@angular-architects/module-federation/src/server/mf-dev-server.js",
    "deploy:gh": "ng build shell --base-href=/microFrontEnd_app/ && npx angular-cli-ghpages --dir=dist/shell"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^20.3.25",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/module-federation": "^21.2.2",
    "@angular-devkit/build-angular": "^21.2.16",
    "@angular/build": "^22.0.3",
    "@angular/cli": "^20.3.6",
    "@angular/compiler-cli": "^20.3.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/jasmine": "~5.1.0",
    "angular-cli-ghpages": "^3.0.2",
    "autoprefixer": "^10.4.17",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ngx-build-plus": "^20.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2",
    "zone.js": "^0.15.1"
  }
}
